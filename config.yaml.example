# ══════════════════════════════════════════════════════════════════════════════
#  Discord Printer Bot — Configuration Example
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to config.yaml and fill in your values.
# Never commit your actual config.yaml with real tokens to version control!
# ══════════════════════════════════════════════════════════════════════════════

# ── Discord Configuration ─────────────────────────────────────────────────────
discord:
  bot_token: "YOUR_DISCORD_BOT_TOKEN_HERE"
  # Optional: Restrict bot to specific roles
  allowed_role_ids:
    - 123456789012345678
  # Optional: Bot admins (can use admin commands)
  admin_ids:
    - 123456789012345678

# ── Printers ──────────────────────────────────────────────────────────────────
# You can configure multiple printers. Each user can switch between them.
#
# Supported connection types:
#   - moonraker: For Klipper/Moonraker setups (local or remote)
#   - octoprint: For OctoPrint setups (local or remote)
#   - octoeverywhere: For remote access via OctoEverywhere cloud
#
# Printer permissions:
#   - owner_id: Discord user ID of the printer owner
#   - is_private: If true, only owner + allowed_users can access
#   - allowed_users: List of Discord user IDs with access
#
# Example with multiple printers:
printers:
  - name: "Voron 2.4"
    # Moonraker connection (local)
    moonraker:
      url: "http://192.168.1.100:7125"
      api_key: ""
    # Optional: OctoEverywhere for remote access
    octoeverywhere:
      key: ""
    # Camera configuration
    camera:
      snapshot_url: "http://192.168.1.100/webcam/?action=snapshot"
      stream_url: "http://192.168.1.100/webcam/?action=stream"
    # Permissions
    owner_id: 123456789012345678
    is_private: false
    allowed_users:
      - 987654321098765432

  - name: "Ender 3 Pro"
    # OctoPrint connection
    octoprint:
      url: "http://192.168.1.101:5000"
      api_key: "YOUR_OCTOPRINT_API_KEY"
    camera:
      snapshot_url: "http://192.168.1.101:5000/plugin/mjpegstreamer-adaptive/?action=snapshot"
      stream_url: "http://192.168.1.101:5000/plugin/mjpegstreamer-adaptive/?action=stream"
    owner_id: 123456789012345678
    is_private: true
    allowed_users:
      - 987654321098765432

  - name: "Remote Prusa"
    # OctoEverywhere only (cloud proxy for remote access)
    octoeverywhere:
      key: "YOUR_OCTOEVERYWHERE_KEY"
    camera:
      snapshot_url: ""
      stream_url: ""
    owner_id: 123456789012345678
    is_private: false
    allowed_users: []

# ── Legacy Single Printer Config (optional) ───────────────────────────────────
# If you only have one printer, you can use this simpler format instead:
#
# printer_name: "My Printer"
# moonraker:
#   url: "http://192.168.1.100:7125"
#   api_key: ""
# octoprint:
#   url: "http://192.168.1.101:5000"
#   api_key: ""
# octoeverywhere:
#   key: ""
# camera:
#   snapshot_url: ""
#   stream_url: ""

# ── Temperature Presets ───────────────────────────────────────────────────────
temp_presets:
  hotend:
    PLA: 200
    PETG: 230
    ABS: 245
    TPU: 220
    Nylon: 260
    "Cool Down": 0
  bed:
    PLA: 60
    PETG: 80
    ABS: 100
    TPU: 60
    Nylon: 80
    "Cool Down": 0

# ── Macro Configuration ───────────────────────────────────────────────────────
macros:
  # Human-readable aliases for macros
  aliases:
    LOAD_FILAMENT: "🔄 Load Filament"
    UNLOAD_FILAMENT: "🔄 Unload Filament"
    PARK: "🅿️ Park Nozzle"
    # Add your own: MACRO_NAME: "Display Name"
  # Macros per page in the list
  per_page: 8

# ── File Browser Configuration ────────────────────────────────────────────────
files:
  files_per_page: 10
  sort_by: "modified"  # "modified" or "name"
  sort_order: "desc"   # "desc" or "asc"

# ── Monitoring Configuration ──────────────────────────────────────────────────
monitoring:
  poll_interval: 30  # seconds between status checks (for future notifications)

# ── Safety Settings ───────────────────────────────────────────────────────────
safety:
  emergency_stop_enabled: true
  emergency_stop_confirm: true  # Require confirmation for E-stop
